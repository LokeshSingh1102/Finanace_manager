generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String    @id @default(uuid())
  name     String
  username String    @unique
  password String
  expense  Expense[]
}

model Expense {
  id         Int    @id @default(autoincrement())
  category   String
  payment_to String @unique
  amount     Int
  userId     String
  user       User   @relation(fields: [userId], references: [id])
}

model Budget {
  id          Int    @id @default(autoincrement())
  category    String @unique
  curr_money  Int
  total_money Int
}
